#!/usr/bin/env bash

set -euo pipefail

ARCHIVE_DIR="$HOME/log-archives"
LOG_FILE="$ARCHIVE_DIR/archive.log"

usage() {
    cat <<EOF
Usage:
  log-archive <log-directory>            Archive logs now
  log-archive --schedule <log-directory> Install a nightly cron job (midnight)
  log-archive --unschedule               Remove the cron job
EOF
    exit 1
}

[[ $# -eq 0 ]] && usage

# --- Schedule management ---

if [[ "$1" == "--unschedule" ]]; then
    crontab -l 2>/dev/null | grep -v "log-archive" | crontab -
    echo "Cron job removed."
    exit 0
fi

if [[ "$1" == "--schedule" ]]; then
    [[ $# -ne 2 ]] && usage
    SCRIPT_PATH="$(realpath "$0")"
    LOG_DIR_ABS="$(realpath "$2")"
    CRON_LINE="0 0 * * * $SCRIPT_PATH $LOG_DIR_ABS"
    # Remove any existing log-archive cron entry, then add the new one
    EXISTING=$(crontab -l 2>/dev/null || true)
    { echo "$EXISTING" | grep -v "log-archive"; echo "$CRON_LINE"; } | crontab -
    echo "Cron job installed: runs nightly at midnight for '$LOG_DIR_ABS'."
    exit 0
fi

# --- Archive ---

LOG_DIR="$1"

if [[ ! -d "$LOG_DIR" ]]; then
    echo "Error: '$LOG_DIR' is not a directory or does not exist." >&2
    exit 1
fi

mkdir -p "$ARCHIVE_DIR"

TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
ARCHIVE_NAME="logs_archive_${TIMESTAMP}.tar.gz"
ARCHIVE_PATH="$ARCHIVE_DIR/$ARCHIVE_NAME"

tar -czf "$ARCHIVE_PATH" -C "$(dirname "$LOG_DIR")" "$(basename "$LOG_DIR")"

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Archived '$LOG_DIR' -> '$ARCHIVE_PATH'" | tee -a "$LOG_FILE"
